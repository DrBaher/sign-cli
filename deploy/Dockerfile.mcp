# Stdio MCP-server container for sign-cli.
#
# For Glama and any MCP host that runs servers over stdio (the standard MCP
# transport). Installs the published npm package and starts `sign mcp serve`,
# which speaks MCP across the container's stdin/stdout.
#
# sign-cli is JS/WASM only — SQLite is Node 22's built-in `node:sqlite`, so no
# build toolchain or native modules are required.
#
# NOTE: this is the STDIO MCP server. deploy/Dockerfile is a separate
# HTTP-demo container (`sign serve` on a port) — don't confuse the two.
#
# Build:  docker build -f deploy/Dockerfile.mcp -t sign-cli-mcp .
#         (pin a version: --build-arg SIGN_CLI_VERSION=0.7.1)
# Run:    docker run -i --rm sign-cli-mcp            # MCP over stdio
# Public sandbox: override the command to block mutating tools, e.g.
#         docker run -i --rm sign-cli-mcp mcp serve --read-only true

FROM node:22-slim

ARG SIGN_CLI_VERSION=latest
RUN npm install -g @drbaher/sign-cli@${SIGN_CLI_VERSION} \
    && npm cache clean --force

# Writable home for the local provider's ephemeral SQLite DB / key + store dirs.
ENV SIGN_DB_PATH=/data/sign.db \
    SIGN_LOCAL_STORE_DIR=/data/store \
    SIGN_LOCAL_KEY_DIR=/data/keys
RUN mkdir -p /data && chown -R node:node /data
USER node
WORKDIR /data

ENTRYPOINT ["sign"]
CMD ["mcp", "serve"]
